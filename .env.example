# Database configuration (for docker-compose)
DB_NAME=bidmart_auction
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# Database configuration (for Spring Boot)
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/bidmart_auction
JDBC_DATABASE_USERNAME=your_db_username
JDBC_DATABASE_PASSWORD=your_db_password

# RabbitMQ configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=your_rabbitmq_password

# Service URLs
WALLET_SERVICE_URL=http://localhost:8084
